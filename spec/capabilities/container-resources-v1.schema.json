{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:redeven:capability:container-resources:v1",
  "title": "Redeven Container Resources Capability v1",
  "description": "Redeven-owned business capability contract for Docker and Podman container resources. This is not a ReDevPlugin platform-core schema.",
  "oneOf": [
    { "$ref": "#/$defs/status_request" },
    { "$ref": "#/$defs/status_response" },
    { "$ref": "#/$defs/container_list_request" },
    { "$ref": "#/$defs/container_list_response" },
    { "$ref": "#/$defs/container_inspect_request" },
    { "$ref": "#/$defs/container_inspect_response" },
    { "$ref": "#/$defs/container_action_request" },
    { "$ref": "#/$defs/container_start_request" },
    { "$ref": "#/$defs/logs_tail_request" },
    { "$ref": "#/$defs/image_pull_request" },
    { "$ref": "#/$defs/start_preflight_plan" }
  ],
  "$defs": {
    "schema_version": {
      "type": "string",
      "const": "redeven.capability.container_resources.v1"
    },
    "capability_id": {
      "type": "string",
      "const": "redeven.capability.container_resources"
    },
    "capability_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "engine": {
      "type": "string",
      "enum": ["docker", "podman"]
    },
    "method": {
      "type": "string",
      "enum": [
        "containers.status",
        "containers.list",
        "containers.inspect",
        "containers.start.preflight",
        "containers.start",
        "containers.stop",
        "containers.restart",
        "containers.remove",
        "containers.logs.tail",
        "images.pull"
      ]
    },
    "container_state": {
      "type": "string",
      "enum": ["created", "running", "paused", "restarting", "exited", "stopped", "unknown"]
    },
    "risk_severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["none", "low", "medium", "high", "critical"]
    },
    "mount_type": {
      "type": "string",
      "enum": ["bind", "volume", "tmpfs", "other"]
    },
    "mount_source_kind": {
      "type": "string",
      "enum": ["host_path", "named_volume", "tmpfs", "container_socket", "unknown"]
    },
    "status_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" }
      }
    },
    "status_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "capability_id", "capability_version", "engine", "available"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "capability_id": { "$ref": "#/$defs/capability_id" },
        "capability_version": { "$ref": "#/$defs/capability_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "available": { "type": "boolean" },
        "engine_version": { "type": "string" }
      }
    },
    "container_list_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "all": { "type": "boolean" }
      }
    },
    "container_list_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "capability_id", "engine", "containers"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "capability_id": { "$ref": "#/$defs/capability_id" },
        "engine": { "$ref": "#/$defs/engine" },
        "containers": {
          "type": "array",
          "items": { "$ref": "#/$defs/container_summary" }
        }
      }
    },
    "container_inspect_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "engine", "container_id"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "container_id": { "type": "string", "minLength": 1 }
      }
    },
    "container_inspect_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "capability_id", "engine", "container"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "capability_id": { "$ref": "#/$defs/capability_id" },
        "engine": { "$ref": "#/$defs/engine" },
        "container": { "$ref": "#/$defs/container_inspect" }
      }
    },
    "container_action_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "engine", "container_id"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "container_id": { "type": "string", "minLength": 1 },
        "force": { "type": "boolean" },
        "timeout_sec": { "type": "integer", "minimum": 0 }
      }
    },
    "container_start_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "engine", "container_id"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "container_id": { "type": "string", "minLength": 1 }
      }
    },
    "logs_tail_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "engine", "container_id"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "container_id": { "type": "string", "minLength": 1 },
        "tail_lines": { "type": "integer", "minimum": 0 },
        "since_unix_ms": { "type": "integer", "minimum": 0 },
        "follow": { "type": "boolean" }
      }
    },
    "image_pull_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "engine", "image_ref"],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "engine": { "$ref": "#/$defs/engine" },
        "image_ref": { "type": "string", "minLength": 1 }
      }
    },
    "container_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_id", "image", "state"],
      "properties": {
        "container_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "image": { "$ref": "#/$defs/image_summary" },
        "state": { "$ref": "#/$defs/container_state" },
        "created_at_unix_ms": { "type": "integer", "minimum": 0 },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/$defs/port_summary" }
        }
      }
    },
    "container_inspect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["container_id", "image", "state", "runtime", "labels"],
      "properties": {
        "container_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "image": { "$ref": "#/$defs/image_summary" },
        "state": { "$ref": "#/$defs/container_state" },
        "created_at_unix_ms": { "type": "integer", "minimum": 0 },
        "runtime": { "$ref": "#/$defs/runtime_summary" },
        "labels": { "$ref": "#/$defs/label_summary" },
        "ports": {
          "type": "array",
          "items": { "$ref": "#/$defs/port_summary" }
        },
        "mounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/mount_summary" }
        },
        "devices": {
          "type": "array",
          "items": { "$ref": "#/$defs/device_summary" }
        }
      }
    },
    "image_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest_pinned"],
      "properties": {
        "reference": { "type": "string" },
        "digest": { "type": "string" },
        "digest_pinned": { "type": "boolean" }
      }
    },
    "runtime_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["privileged", "env", "labels"],
      "properties": {
        "privileged": { "type": "boolean" },
        "network_mode": { "type": "string" },
        "pid_mode": { "type": "string" },
        "ipc_mode": { "type": "string" },
        "restart_policy": { "type": "string" },
        "env": { "$ref": "#/$defs/env_summary" },
        "labels": { "$ref": "#/$defs/label_summary" },
        "mounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/mount_summary" }
        },
        "devices": {
          "type": "array",
          "items": { "$ref": "#/$defs/device_summary" }
        },
        "cap_add": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cap_drop": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "env_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "plain_count", "secret_like_count"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "plain_count": { "type": "integer", "minimum": 0 },
        "secret_like_count": { "type": "integer", "minimum": 0 }
      }
    },
    "label_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "plain_count", "secret_like_count"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "plain_count": { "type": "integer", "minimum": 0 },
        "secret_like_count": { "type": "integer", "minimum": 0 }
      }
    },
    "mount_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source_kind", "read_only"],
      "properties": {
        "type": { "$ref": "#/$defs/mount_type" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "source_kind": { "$ref": "#/$defs/mount_source_kind" },
        "read_only": { "type": "boolean" },
        "sensitive_path": { "type": "boolean" },
        "container_socket": { "type": "boolean" }
      }
    },
    "device_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "host_path": { "type": "string" },
        "container_path": { "type": "string" },
        "permissions": { "type": "string" },
        "sensitive_path": { "type": "boolean" }
      }
    },
    "port_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port"],
      "properties": {
        "protocol": { "type": "string" },
        "host_ip": { "type": "string" },
        "host_port": { "type": "integer", "minimum": 0 },
        "port": { "type": "integer", "minimum": 0 }
      }
    },
    "target_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "container_id", "target_hash"],
      "properties": {
        "engine": { "$ref": "#/$defs/engine" },
        "container_id": { "type": "string", "minLength": 1 },
        "container_name": { "type": "string" },
        "target_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "risk_flag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "title"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "$ref": "#/$defs/risk_severity" },
        "title": { "type": "string", "minLength": 1 },
        "detail": { "type": "string" },
        "admin_required": { "type": "boolean" }
      }
    },
    "start_preflight_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "capability_id",
        "capability_version",
        "method",
        "request",
        "target",
        "image",
        "runtime",
        "risk_level",
        "risk_flags",
        "requires_admin"
      ],
      "properties": {
        "schema_version": { "$ref": "#/$defs/schema_version" },
        "capability_id": { "$ref": "#/$defs/capability_id" },
        "capability_version": { "$ref": "#/$defs/capability_version" },
        "method": { "const": "containers.start" },
        "request": { "$ref": "#/$defs/container_start_request" },
        "target": { "$ref": "#/$defs/target_summary" },
        "image": { "$ref": "#/$defs/image_summary" },
        "runtime": { "$ref": "#/$defs/runtime_summary" },
        "risk_level": { "$ref": "#/$defs/risk_level" },
        "risk_flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/risk_flag" }
        },
        "requires_admin": { "type": "boolean" },
        "summary": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
