{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@floegence/floe-webapp-core": ["node_modules/@floegence/floe-webapp-core"],
      "@floegence/floe-webapp-core/*": ["node_modules/@floegence/floe-webapp-core/dist/*"],
      "solid-js": ["node_modules/solid-js"],
      "solid-js/*": ["node_modules/solid-js/*"],
      "vitest": ["node_modules/vitest"]
    },
    "jsx": "preserve",
    "jsxImportSource": "solid-js"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../internal/flower_ui/src/**/*.ts", "../internal/flower_ui/src/**/*.tsx"]
}
