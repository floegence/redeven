{
  "name": "@floegence/redeven-envapp-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build && node scripts/checkInitialBuildBudget.mjs",
    "check:initial-budget": "node scripts/checkInitialBuildBudget.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"vite.config.ts\" \"vitest.browser.config.ts\" \"eslint.config.mjs\" --max-warnings=0 && cd ../../flower_ui && NODE_PATH=../envapp/ui_src/node_modules ../envapp/ui_src/node_modules/.bin/eslint -c eslint.config.mjs \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"vite.config.ts\" \"vitest.browser.config.ts\" \"eslint.config.mjs\" --fix && cd ../../flower_ui && NODE_PATH=../envapp/ui_src/node_modules ../envapp/ui_src/node_modules/.bin/eslint -c eslint.config.mjs \"src/**/*.{ts,tsx}\" --fix",
    "check:workbench-wheel": "node scripts/checkWorkbenchWheelContract.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 8096",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test scripts/checkThemeColorSources.node-test.mjs scripts/initialBuildGraphPolicy.node-test.mjs scripts/redevpluginRuntimeFixture.node-test.mjs scripts/terminalAgentIconIntegrity.node-test.mjs scripts/terminalCarrierRunnerPolicy.node-test.mjs scripts/terminalCarrierThreshold.node-test.mjs && node scripts/checkThemeColorSources.mjs && vitest run --environment=node --exclude \"src/**/*.browser.test.tsx\" --maxWorkers=2 --testTimeout=10000",
    "test:browser": "node scripts/runVitestBrowser.mjs",
    "test:built-dist-shell": "node scripts/checkPackagedRenderer.mjs",
    "test:terminal-carrier": "node scripts/checkTerminalRecoveryCarrier.mjs",
    "test:terminal-performance": "node scripts/checkTerminalInteractionPerformance.mjs"
  },
